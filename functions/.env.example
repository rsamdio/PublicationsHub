# Copy to .env in this folder (never commit .env — it is gitignored).
# Required for deploy / emulator; variable names must match exactly.

# --- Cloudflare R2 (PDFs + covers) — S3-compatible API ---
# Create bucket + API token (Object Read & Write) in Cloudflare Dashboard → R2.
# Public URL: enable R2.dev subdomain or attach a custom domain, then set R2_PUBLIC_BASE_URL to that origin (no trailing slash).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY: set only in Secret Manager (exact names):
#   echo -n 'your_r2_access_key_id' | firebase functions:secrets:set R2_ACCESS_KEY_ID
#   echo -n 'your_r2_secret_access_key' | firebase functions:secrets:set R2_SECRET_ACCESS_KEY

# Optional: default Firebase Storage bucket (staging for large PDF uploads before R2).
# STORAGE_BUCKET=your-project.firebasestorage.app

# Optional: Realtime Database URL for Firestore→RTDB mirror (often omitted from FIREBASE_CONFIG).
# FIREBASE_DATABASE_URL=https://your-project-default-rtdb.<region>.firebasedatabase.app
