# Copy to .env in this folder (never commit .env — it is gitignored).
# Required for deploy / emulator; variable names must match exactly.

GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=your-data-repo-name
GITHUB_BRANCH=main

# GITHUB_TOKEN: set only in Secret Manager (name must be GITHUB_TOKEN):
#   echo -n 'ghp_...' | firebase functions:secrets:set GITHUB_TOKEN
# Do not put the PAT in this file for production.
